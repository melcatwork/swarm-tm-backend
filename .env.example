# ============================================
# LLM Provider Configuration
# ============================================
# Choose ONE provider: "bedrock" or "anthropic" or "ollama"
LLM_PROVIDER=bedrock

# --- AWS Bedrock (bearer token only, no IAM keys needed) ---
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-bearer-token-here
AWS_REGION=us-east-1
BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Direct Anthropic API ---
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# --- Ollama (local LLM, no API key needed) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:14b

# --- OpenAI API (not recommended for threat modeling) ---
OPENAI_API_KEY=

# ============================================
# LLM Performance Configuration
# ============================================
# These settings apply to all LLM providers
LLM_TEMPERATURE=0.5         # Lower = more consistent, higher = more creative (0.0-1.0)
LLM_MAX_TOKENS=4096         # Maximum tokens per response
LLM_CONTEXT_WINDOW=32000    # Maximum context window size
LLM_TIMEOUT_SECONDS=600     # Timeout for LLM operations (10 minutes)
LLM_RETRY_ATTEMPTS=3        # Number of retry attempts on failure

# ============================================
# Threat Intelligence & Vulnerability Sources (Optional)
# ============================================
# NVD API key for CVE lookups (optional but recommended)
# Without key: 5 requests per 30 seconds (rate limited)
# With key: 50 requests per 30 seconds
# Request free key at: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=

# Enable/disable CVE lookups via NVD (requires internet access)
# Set to 'false' in air-gapped environments without internet
# Default: true
ENABLE_CVE_LOOKUP=true

# GitHub token enables GHSA sync for PoC evidence
# Generate at: https://github.com/settings/tokens (needs public_repo scope)
# GITHUB_TOKEN=

# ============================================
# CORS Configuration (Production)
# ============================================
# Comma-separated list of allowed origins
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# Leave commented for development (defaults to localhost)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
